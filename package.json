{
  "name": "linxaura",
  "type": "module",
  "version": "1.0.0",
  "description": "a blog website",
  "author": "EternityQAQ2 <Eternity_QAQ@outlook.com>",
  "license": "MIT",
  "scripts": {
    "docs:dev": "vuepress dev docs",
    "docs:dev-clean": "vuepress dev docs --clean-cache --clean-temp",
    "docs:build": "vuepress build docs --clean-cache --clean-temp",
    "docs:preview": "http-server docs/.vuepress/dist",
    "gallery:gen": "node scripts/generate-gallery.mjs",
    "vp-update": "npx vp-update",

    "dev:gallery": "cd afilmory && DEV_NEXT_JS=true pnpm --filter web dev",
    "dev": "concurrently -n blog,gallery -c cyan,green \"npm run docs:dev\" \"npm run dev:gallery\"",

    "build:gallery": "cd afilmory/apps/web && pnpm exec vite build --base /gallery-app/",
    "copy:gallery": "rm -rf docs/.vuepress/public/gallery-app && cp -r afilmory/apps/web/dist docs/.vuepress/public/gallery-app",
    "prebuild": "npm run build:gallery && npm run copy:gallery",
    "build": "npm run prebuild && npm run docs:build"
  },
  "devDependencies": {
    "@vuepress/bundler-vite": "2.0.0-rc.30",
    "concurrently": "^9.1.0",
    "exifr": "^7.1.3",
    "http-server": "^14.1.1",
    "typescript": "^6.0.3",
    "vue": "^3.5.34",
    "vuepress": "2.0.0-rc.30",
    "vuepress-theme-plume": "1.0.0-rc.203"
  },
  "engines": {
    "node": "^20.19.0 || >=22.0.0"
  },
  "dependencies": {
    "katex": "^0.17.0"
  }
}
